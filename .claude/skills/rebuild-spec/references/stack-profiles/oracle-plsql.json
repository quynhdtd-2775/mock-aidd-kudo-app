    "permissions-matrix": { "action": "produce", "class": "universal" },
    "behavior-logic": { "action": "produce", "class": "universal" },
    "route-list": { "action": "skip", "class": "web" },
    "screen-list": { "action": "skip", "class": "web" },
    "screen-flow": { "action": "skip", "class": "web" },
