{
  "id": "delphi-vcl",
  "display_name": "Delphi / VCL (desktop, Object Pascal)",
  "detected_language_heading": "Delphi/VCL",
  "detection": {
    "globs": ["*.dpr", "*.dproj", "*.pas", "*.dfm", "*.dpk", "*.inc"]
  },
  "source_encoding": { "primary": "shift_jis", "fallback": "utf-8" },
  "resource_decode": "delphi_hash_escape",
  "artifact_map": {
    "system-overview": { "action": "produce", "class": "universal" },
    "architecture": { "action": "produce", "class": "universal" },
    "data-model": { "action": "produce", "class": "universal" },
    "entities": { "action": "produce", "class": "universal" },
    "user-stories": { "action": "produce", "class": "universal" },
    "feature-list": { "action": "produce", "class": "universal" },
    "business-rules": { "action": "produce", "class": "universal" },
    "permissions": { "action": "produce", "class": "universal" },
    "permissions-matrix": { "action": "produce", "class": "universal" },
    "behavior-logic": { "action": "produce", "class": "universal" },
    "route-list": { "action": "skip", "class": "web" },
    "screen-list": { "action": "produce", "class": "web" },
    "screen-flow": { "action": "produce", "class": "web" },
    "api-map": { "action": "skip", "class": "web" },
    "crud-matrix": { "action": "produce", "class": "stack-specific" },
    "db-objects": { "action": "produce", "class": "stack-specific" }
  },
  "screen_source": "dfm-form",
  "extractors": ["extract_sql_schema", "extract_data_flow", "extract_form_nav"],
  "probe": { "bootable": false },
  "module_layout": "one-spec-per-unit",
  "component_boundary_globs": ["*.dpr", "*.dproj", "*.dpk"],
  "shared_layer_dirs": ["Common", "DB"],
  "re_contract": true
}
