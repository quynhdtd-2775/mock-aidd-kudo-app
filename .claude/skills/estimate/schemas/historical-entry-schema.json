{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-estimate.dev/schemas/historical-entry-schema.json",
  "title": "Historical Calibration Entry",
  "description": "Canonical schema for historical estimate entries used in KB calibration",
  "type": "object",
  "required": ["version", "type", "project", "estimate"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "type": {
      "type": "string",
      "enum": ["accepted", "actual"]
    },
    "project": {
      "type": "object",
      "required": ["name", "date"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Anonymous slug (e.g. project-001), NOT real project name"
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "domain": {
          "type": "string",
          "description": "Generic domain label (e-commerce, saas, fintech, etc.)"
        },
        "tech_stack": {
          "type": "array",
          "items": { "type": "string" }
        },
        "team_size": {
          "type": "integer",
          "minimum": 1
        },
        "team_experience": {
          "type": "string",
          "enum": ["junior", "mid", "senior", "mixed"]
        }
      },
      "additionalProperties": false
    },
    "estimate": {
      "type": "object",
      "required": ["total_md", "tasks"],
      "properties": {
        "total_md": {
          "type": "number",
          "minimum": 0
        },
        "multipliers_used": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "value"],
            "properties": {
              "name": { "type": "string" },
              "key": { "type": "string" },
              "value": { "type": "number" }
            }
          }
        },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["task_type", "total_md"],
            "properties": {
              "task_type": {
                "type": "string",
                "description": "KB category key (e.g. crud, authentication)"
              },
              "complexity": {
                "type": "string",
                "enum": ["simple", "medium", "complex", "very_complex"]
              },
              "total_md": {
                "type": "number",
                "minimum": 0
              },
              "story_points": {
                "type": "integer",
                "minimum": 0
              },
              "effort": {
                "type": "object",
                "description": "Per-role effort in man-days",
                "additionalProperties": {
                  "type": "number",
                  "minimum": 0
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "actual": {
      "type": "object",
      "properties": {
        "total_md": {
          "type": "number",
          "minimum": 0
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["task_type", "actual_md"],
            "properties": {
              "task_type": { "type": "string" },
              "actual_md": {
                "type": "number",
                "minimum": 0
              },
              "effort": {
                "type": "object",
                "additionalProperties": {
                  "type": "number",
                  "minimum": 0
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "if": {
    "properties": { "type": { "const": "actual" } }
  },
  "then": {
    "required": ["version", "type", "project", "estimate", "actual"]
  },
  "additionalProperties": false
}
