{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-estimate.dev/schemas/breakdown-output-schema.json",
  "title": "Task Breakdown Output",
  "description": "Schema for task breakdown output with Epic > Story > Task hierarchy per team role",
  "type": "object",
  "required": [
    "project_name",
    "breakdown_level",
    "language",
    "source",
    "generated_date",
    "active_roles",
    "role_names",
    "epics"
  ],
  "properties": {
    "project_name": {
      "type": "string",
      "description": "Name of the project being broken down"
    },
    "breakdown_level": {
      "type": "integer",
      "enum": [1, 2, 3],
      "description": "Granularity level: 1=Epic overview, 2=Stories, 3=Tasks+AC"
    },
    "language": {
      "type": "string",
      "enum": ["en", "vi", "ja"],
      "description": "Output language"
    },
    "source": {
      "type": "string",
      "enum": ["pre-estimate", "post-estimate"],
      "description": "Input mode: pre-estimate (raw docs) or post-estimate (estimate JSON)"
    },
    "source_file": {
      "type": "string",
      "description": "Path or name of the source document or estimate JSON"
    },
    "generated_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date breakdown was generated (YYYY-MM-DD)"
    },
    "active_roles": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Ordered list of role slugs used in this breakdown"
    },
    "role_names": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Mapping of role slug to display name"
    },
    "epics": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/epic" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "epic": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Epic ID (e.g. E1, E2)"
        },
        "name": {
          "type": "string",
          "description": "Epic name"
        },
        "description": {
          "type": "string",
          "description": "Brief description of the epic"
        },
        "total_md": {
          "type": ["number", "null"],
          "description": "Total man-days for this epic (null in pre-estimate)"
        },
        "stories": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/story" }
        }
      },
      "additionalProperties": false
    },
    "story": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Story ID (e.g. S1.1, S1.2)"
        },
        "name": {
          "type": "string",
          "description": "Story name (user story format preferred)"
        },
        "description": {
          "type": "string",
          "description": "Brief description of the story"
        },
        "estimate_ref": {
          "type": ["string", "null"],
          "description": "Reference to estimate JSON task ID (post-estimate only)"
        },
        "total_md": {
          "type": ["number", "null"],
          "description": "Total man-days for this story (null in pre-estimate)"
        },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/task" }
        }
      },
      "additionalProperties": false
    },
    "task": {
      "type": "object",
      "required": ["id", "name", "role"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Task ID (e.g. FE-1.1.1, BE-1.1.1)"
        },
        "name": {
          "type": "string",
          "description": "Task name"
        },
        "role": {
          "type": "string",
          "description": "Role slug (must be in active_roles)"
        },
        "md": {
          "type": ["number", "null"],
          "description": "Man-days for this task (null in pre-estimate)"
        },
        "description": {
          "type": "string",
          "description": "Detailed task description"
        },
        "checklist": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Implementation steps checklist"
        },
        "acceptance_criteria": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Definition of done criteria"
        }
      },
      "additionalProperties": false
    }
  }
}
